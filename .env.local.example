# URL publique de l'API Directus (pour le client côté front)
NEXT_PUBLIC_DIRECTUS_URL=https://your-directus-instance.directus.app

# Token serveur sécurisé (jamais exposé côté client)
DIRECTUS_SERVER_TOKEN=your_static_token_here

# Hostname Directus pour next/image
DIRECTUS_HOST=your-directus-instance.directus.app

# Protection Basic Auth staging (optionnel — format user:password)
# STAGING_AUTH=vsonus:MotDePasse

# Stripe (optionnel - pour les acomptes)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
